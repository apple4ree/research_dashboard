# Copy to .env.local and fill in real values. .env.local is gitignored.

# ─── Database ───────────────────────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"

# ─── NextAuth.js (web sign-in) ──────────────────────────────────────────────
# Generate with: openssl rand -base64 33
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Register a GitHub OAuth App at https://github.com/settings/applications/new
# Authorization callback URL: <AUTH_URL>/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# ─── Skill API (Phase 1) ────────────────────────────────────────────────────
# JWT signing secret for tokens minted by /api/auth/device/exchange.
# Generate with: openssl rand -base64 32
LABHUB_JWT_SECRET=""

# GitHub OAuth App for "LabHub CLI" (Device Flow enabled).
# Phase 1 only verifies access tokens — the skill itself uses this in Phase 2.
LABHUB_CLI_GITHUB_CLIENT_ID=""

# ─── Slack notifications ────────────────────────────────────────────────────
# Slack Incoming Webhook URL. When set, new notices are posted to the channel
# the webhook is bound to. Leave empty to disable.
# Create one at: https://api.slack.com/apps → your app → Incoming Webhooks
SLACK_NOTICE_WEBHOOK_URL=""

# Optional: public base URL used to build notice links in Slack messages.
# Falls back to AUTH_URL when unset.
NOTICE_PUBLIC_BASE_URL=""

# ─── Chatbot (litellm proxy) ────────────────────────────────────────────────
# Provider API key used by the litellm proxy. Paste your Gemini / Anthropic /
# OpenAI key here — the proxy forwards requests using it.
CHATBOT_KEY=""

# litellm-format model id, "<provider>/<model>".
CHATBOT_MODEL="gemini/gemini-3.1-pro-preview"

# Master key the litellm proxy requires from its callers (Node → litellm).
# Local-only secret; rotate freely.
LITELLM_MASTER_KEY="sk-local-only"

# Optional override for the litellm proxy URL (default: http://127.0.0.1:4001).
# LITELLM_BASE_URL=""
