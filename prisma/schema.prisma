// This is your Prisma schema file.
// Mirrors lib/types.ts with extensibility columns for future external-source sync.

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ========== Members ==========
model Member {
  login              String    @id
  displayName        String
  role               String
  avatarUrl          String?
  email              String?   @unique // OAuth email (nullable until first login)
  githubLogin        String?   @unique // GitHub handle (nullable until admin sets it)
  bio                String?
  pinnedProjectSlugs String    // JSON array stored as string
  source             String    @default("internal")
  externalId         String?   @unique
  lastSyncedAt       DateTime?

  authoredPapers      PaperAuthor[]
  memberProjects      ProjectMember[]
  triggeredRuns       ExperimentRun[]
  authoredDiscussions Discussion[]
  authoredReplies     Reply[]
  authoredNotices         Notice[]
  authoredNoticeComments  NoticeComment[]
  wikiStars               WikiEntityStar[]
  authoredExperiments     Experiment[]
  authoredEvents      ActivityEvent[]
  journalEntries      ResearchEntry[]

  // Back-relation from NextAuth User (optional one-to-one)
  user User?
}

// ========== NextAuth.js v5 tables ==========
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  // Link to our domain Member by login (nullable until first successful signIn)
  memberLogin String? @unique
  member      Member? @relation(fields: [memberLogin], references: [login], onDelete: SetNull)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ========== Projects ==========
model Project {
  slug           String    @id
  name           String
  description    String
  tags           String    // JSON array
  pinned         Boolean
  createdAt      DateTime
  updatedAt      DateTime
  source         String    @default("internal")
  externalId     String?   @unique
  lastSyncedAt   DateTime?
  githubRepo     String?   // "owner/repo" when connected to GitHub
  readmeMarkdown String?   // optional synced README content (from GitHub or internal)
  targetVenue    String?   // target conference / journal shown in Overview KPI bar

  // Operational fs path (set by an admin) of the local git checkout for this
  // project. Used by tooling that mirrors files into LabHub. Optional — purely
  // informational projects can leave it null.
  localPath      String?

  repos        ProjectRepo[]
  members      ProjectMember[]
  papers       Paper[]
  releases     Release[]
  runs         ExperimentRun[]
  events       ActivityEvent[]
  entries      ResearchEntry[]
  milestones   Milestone[]
  todos        TodoItem[]
  discussions  Discussion[]
  wikiTypes    WikiType[]
  wikiEntities WikiEntity[]
  flowEvents   FlowEvent[]
  flowEventTaskLinks FlowEventTaskLink[]
  experiments  Experiment[]
}

model ProjectMember {
  projectSlug String
  memberLogin String
  project     Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  member      Member  @relation(fields: [memberLogin], references: [login], onDelete: Cascade)

  @@id([projectSlug, memberLogin])
}

model ProjectRepo {
  id          Int     @id @default(autoincrement())
  projectSlug String
  label       String
  url         String
  project     Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
}

// ========== Papers ==========
model Paper {
  id           String    @id
  title        String
  projectSlug  String
  stage        String
  venue        String?
  deadline     DateTime?
  draftUrl     String?
  pdfUrl       String?
  source       String    @default("internal")
  externalId   String?   @unique
  lastSyncedAt DateTime?

  project Project       @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  authors PaperAuthor[]
}

model PaperAuthor {
  paperId     String
  authorLogin String
  position    Int
  paper       Paper  @relation(fields: [paperId], references: [id], onDelete: Cascade)
  author      Member @relation(fields: [authorLogin], references: [login], onDelete: Cascade)

  @@id([paperId, authorLogin])
}

// ========== Experiment Runs ==========
model ExperimentRun {
  id               String    @id
  name             String
  projectSlug      String
  status           String
  startedAt        DateTime
  durationSec      Int?
  triggeredByLogin String
  summary          String?
  stepsJson        String?
  source           String    @default("internal")
  externalId       String?   @unique
  lastSyncedAt     DateTime?
  // optional grouping under an Experiment (the bigger "실험 단위")
  experimentId     String?

  project     Project     @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  triggeredBy Member      @relation(fields: [triggeredByLogin], references: [login], onDelete: Restrict)
  experiment  Experiment? @relation(fields: [experimentId], references: [id], onDelete: SetNull)

  @@index([experimentId])
}

// A bigger "실험 단위" — gathers multiple ExperimentRuns + Results under one
// hypothesis/plan. Wiki entities can be copied here when they describe a
// concrete experiment rather than a static concept.
model Experiment {
  id                 String   @id @default(cuid())
  projectSlug        String
  title              String
  status             String   @default("planned") // 'planned' | 'running' | 'completed' | 'archived'
  hypothesis         String   @default("")
  bodyMarkdown       String   @default("")
  // Provenance: which wiki entity (if any) this was copied from. Both
  // columns store the source pointer so we can render a "copied from
  // wiki:foo" backlink without joining at query time.
  sourceWikiSlug     String?
  sourceWikiEntityId String?
  createdByLogin     String
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  project   Project            @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  createdBy Member             @relation(fields: [createdByLogin], references: [login], onDelete: Restrict)
  runs      ExperimentRun[]
  results   ExperimentResult[]

  @@index([projectSlug, status, createdAt])
}

model ExperimentResult {
  id           String   @id @default(cuid())
  experimentId String
  title        String
  summary      String   @default("")
  metricsJson  String   @default("[]") // JSON [{label, value}]
  kind         String   @default("benchmark") // 'checkpoint' | 'benchmark' | 'figure-bundle' | 'report' | 'tool'
  publishedAt  DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  experiment  Experiment                   @relation(fields: [experimentId], references: [id], onDelete: Cascade)
  attachments ExperimentResultAttachment[]

  @@index([experimentId, publishedAt])
}

model ExperimentResultAttachment {
  id               Int      @id @default(autoincrement())
  resultId         String
  title            String
  storedPath       String
  originalFilename String?
  mimeType         String?
  sizeBytes        Int?
  position         Int      @default(0)
  createdAt        DateTime @default(now())

  result ExperimentResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  @@index([resultId, position])
}

// ========== Discussions ==========
model Discussion {
  id             String    @id
  category       String
  title          String
  authorLogin    String
  projectSlug    String?
  createdAt      DateTime
  lastActivityAt DateTime
  replyCount     Int
  bodyMarkdown   String
  source         String    @default("internal")
  externalId     String?   @unique
  lastSyncedAt   DateTime?

  author  Member   @relation(fields: [authorLogin], references: [login], onDelete: Restrict)
  project Project? @relation(fields: [projectSlug], references: [slug], onDelete: SetNull)
  replies Reply[]
}

model Reply {
  id           String    @id @default(uuid())
  discussionId String
  authorLogin  String
  createdAt    DateTime
  bodyMarkdown String
  position     Int
  source       String    @default("internal")
  externalId   String?   @unique
  lastSyncedAt DateTime?

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     Member     @relation(fields: [authorLogin], references: [login], onDelete: Restrict)
}

// Site-wide announcements / changelog. Not project-scoped — they appear
// in TopNav so every member sees them. Threaded discussion happens via
// NoticeComment.
model Notice {
  id           String   @id @default(cuid())
  title        String
  bodyMarkdown String
  category     String   @default("update") // 'update' | 'feature' | 'fix' | 'announcement'
  authorLogin  String
  pinned       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  author   Member          @relation(fields: [authorLogin], references: [login], onDelete: Restrict)
  comments NoticeComment[]

  @@index([pinned, createdAt])
}

model NoticeComment {
  id           String   @id @default(cuid())
  noticeId     String
  authorLogin  String
  bodyMarkdown String
  createdAt    DateTime @default(now())

  notice Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  author Member @relation(fields: [authorLogin], references: [login], onDelete: Restrict)

  @@index([noticeId, createdAt])
}

// ========== Releases ==========
model Release {
  id           String    @id
  name         String
  kind         String
  projectSlug  String
  version      String
  publishedAt  DateTime
  description  String?
  downloadUrl  String?
  source       String    @default("internal")
  externalId   String?   @unique
  lastSyncedAt DateTime?

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
}

// ========== Activity events ==========
model ActivityEvent {
  id          String   @id
  type        String
  actorLogin  String
  projectSlug String?
  payload     String
  createdAt   DateTime

  actor   Member   @relation(fields: [actorLogin], references: [login], onDelete: Restrict)
  project Project? @relation(fields: [projectSlug], references: [slug], onDelete: SetNull)
}

// ========== Venues ==========
model Venue {
  id       String   @id
  name     String
  deadline DateTime
  kind     String
}

// ========== Research Journal ==========
model ResearchEntry {
  id            String   @id
  projectSlug   String
  date          DateTime
  type          String   // 'meeting' | 'report' | 'experiment' | 'review'
  authorLogin   String
  title         String
  summary       String
  tags          String   // JSON array
  bodyMarkdown  String
  source        String    @default("internal")
  externalId    String?   @unique
  lastSyncedAt  DateTime?

  project   Project         @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  author    Member          @relation(fields: [authorLogin], references: [login], onDelete: Restrict)
  artifacts EntryArtifact[]
  slides    EntrySlide[]
}

model EntryArtifact {
  id       Int    @id @default(autoincrement())
  entryId  String
  type     String // 'notebook' | 'figure' | 'sheet' | 'csv' | 'doc' | 'slide'
  title    String
  href     String  // for url-mode: external URL; for file-mode: /api/uploads/<id>
  position Int

  // File-mode columns. NULL when the artifact is a plain URL link.
  storedPath       String?  // path under UPLOADS_ROOT, e.g. "<entryId>/<id>-<safe-name>"
  originalFilename String?
  mimeType         String?
  sizeBytes        Int?

  entry ResearchEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model EntrySlide {
  id          Int     @id @default(autoincrement())
  entryId     String
  position    Int     // 0 = summary (implicit), 1+ = narrative
  kind        String  // 'discovery' | 'failure' | 'implement' | 'question' | 'next' | 'metric'
  title       String
  body        String
  chip        String?
  metricsJson String?
  code        String?

  entry ResearchEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
}

model Milestone {
  id          Int      @id @default(autoincrement())
  projectSlug String
  date        DateTime
  label       String
  note        String?
  status      String   // 'past' | 'now' | 'future'
  position    Int

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
}

model TodoItem {
  id          Int      @id @default(autoincrement())
  projectSlug String
  bucket      String   // 'short' | 'mid' | 'long'
  text        String
  done        Boolean  @default(false)
  position    Int

  // Flow J view extensions: each TodoItem can carry a one-line goal, an
  // ordered list of subtasks (JSON), a 3-state status, and a free-form
  // group string used as an in-column "epic" header on the kanban.
  goal     String?
  subtasks String?  // JSON array of strings
  status   String   @default("in_progress")  // 'pending' | 'in_progress' | 'done'
  group    String?  // free-form epic / group name for in-column sub-headers

  project   Project             @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  flowLinks FlowEventTaskLink[]
}

// ========== Wiki (per-project knowledge entities, LLM-maintained) ==========
//
// Karpathy-style wiki: persistent entity pages (e.g. attacks/defenses/concepts
// for an attack-research project). Each project defines its own type registry
// (WikiType), and entities are namespaced by project + id. Source of truth is
// typically a git folder (Project.localPath/wiki/...) — a sync script mirrors
// files into these tables for indexed access from the UI.

model WikiType {
  id          Int      @id @default(autoincrement())
  projectSlug String
  key         String   // 'attack', 'defense', 'concept', 'finding', 'method', ...
  label       String   // display name e.g. 'Attacks'
  position    Int      @default(0)
  description String?

  project Project @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  @@unique([projectSlug, key])
}

model WikiEntity {
  projectSlug     String
  id              String   // slug-style id within the project, e.g. 'trigger_universal'
  type            String   // matches a WikiType.key for the same project
  name            String
  status          String   @default("active") // 'active' | 'deprecated' | 'superseded'
  summaryMarkdown String   @default("")
  bodyMarkdown    String
  sourceFiles     String   @default("[]") // JSON array of relative paths under Project.localPath
  // First-time-ingested timestamp. The "New!" badge fades from this.
  // lastSyncedAt below is bumped on every re-ingest, so reusing it for
  // freshness made the badge sticky on entities that get re-synced often.
  createdAt       DateTime @default(now())
  lastSyncedAt    DateTime
  source          String   @default("wiki-llm")

  project     Project                 @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  attachments WikiEntityAttachment[]
  stars       WikiEntityStar[]
  @@id([projectSlug, id])
  @@index([projectSlug, type])
}

// Per-member favorite/star on a wiki entity. Pinning is local to the
// member — different lab members can star different entities.
model WikiEntityStar {
  memberLogin String
  projectSlug String
  entityId    String
  createdAt   DateTime @default(now())

  member Member     @relation(fields: [memberLogin], references: [login], onDelete: Cascade)
  entity WikiEntity @relation(fields: [projectSlug, entityId], references: [projectSlug, id], onDelete: Cascade)

  @@id([memberLogin, projectSlug, entityId])
  @@index([memberLogin, createdAt])
  @@index([projectSlug, entityId])
}

model WikiEntityAttachment {
  id               Int      @id @default(autoincrement())
  projectSlug      String
  entityId         String
  title            String
  storedPath       String
  originalFilename String?
  mimeType         String?
  sizeBytes        Int?
  position         Int      @default(0)
  createdAt        DateTime @default(now())

  entity WikiEntity @relation(fields: [projectSlug, entityId], references: [projectSlug, id], onDelete: Cascade)
  @@index([projectSlug, entityId, position])
}

// ========== Flow J view (event timeline + task kanban) ==========
//
// FlowEvent rows describe discrete research events (a result, a pivot, a
// design decision, an incident). Multiple events can share a `source` (a
// progress markdown file) when one writeup contains several distinct
// activities.
//
// FlowEventTaskLink connects events to TodoItems (M:N). The same event can
// belong to multiple tasks; the same task can have many events.
//
// FlowEventComment is inline Q&A on event cards.

model FlowEvent {
  id          Int      @id @default(autoincrement())
  projectSlug String
  date        String   // 'YYYY-MM-DD HH:mm' display string
  source      String   // progress filename — sourceContent lookup + task linking
  title       String
  summary     String
  tone        String   // 'milestone' | 'pivot' | 'result' | 'incident' | 'design' | 'deprecated'
  bullets     String?  // JSON array of strings
  numbers     String?  // JSON array of { label, value }
  tags        String?  // JSON array of strings
  bodyMarkdown String? // optional copy of the source progress_*.md body sent at ingest time
  position    Int      @default(0)

  project     Project                @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  comments    FlowEventComment[]
  taskLinks   FlowEventTaskLink[]
  attachments FlowEventAttachment[]
  @@index([projectSlug, source])
  @@index([projectSlug, date])
}

model FlowEventAttachment {
  id               Int      @id @default(autoincrement())
  flowEventId      Int
  title            String
  storedPath       String
  originalFilename String?
  mimeType         String?
  sizeBytes        Int?
  position         Int      @default(0)
  createdAt        DateTime @default(now())

  flowEvent FlowEvent @relation(fields: [flowEventId], references: [id], onDelete: Cascade)
  @@index([flowEventId, position])
}

model FlowEventComment {
  id          Int      @id @default(autoincrement())
  flowEventId Int
  authorLogin String?  // nullable for anonymous (PUBLIC_MODE)
  body        String
  createdAt   DateTime @default(now())

  flowEvent FlowEvent @relation(fields: [flowEventId], references: [id], onDelete: Cascade)
  @@index([flowEventId, createdAt])
}

model FlowEventTaskLink {
  id          Int      @id @default(autoincrement())
  projectSlug String
  flowEventId Int
  todoId      Int
  source      String   @default("manual")  // 'llm' | 'manual'
  createdAt   DateTime @default(now())

  project   Project   @relation(fields: [projectSlug], references: [slug], onDelete: Cascade)
  flowEvent FlowEvent @relation(fields: [flowEventId], references: [id], onDelete: Cascade)
  todo      TodoItem  @relation(fields: [todoId], references: [id], onDelete: Cascade)
  @@unique([flowEventId, todoId])
  @@index([projectSlug])
}
